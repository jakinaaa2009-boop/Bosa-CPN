# API base URL (trailing slash is OK — it is stripped).
#
# --- Local backend ---
# NEXT_PUBLIC_API_URL=http://localhost:5000
#
# --- Local `npm run dev` + HTTPS Railway API ---
# Trailing slash OK. During development, requests are proxied via /backend-proxy (no CORS).
# NEXT_PUBLIC_API_URL=https://your-app.up.railway.app
#
# Optional: force proxy on/off (auto is usually enough)
# NEXT_PUBLIC_USE_API_PROXY=true
# NEXT_PUBLIC_USE_API_PROXY=false
#
NEXT_PUBLIC_API_URL=http://localhost:5000

# Optional: R2 public hostname for next/image (e.g. pub-xxxxx.r2.dev)
# NEXT_PUBLIC_R2_IMAGE_HOSTNAME=pub-xxxxx.r2.dev
