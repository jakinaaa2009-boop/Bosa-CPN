PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/lucky_draw
JWT_SECRET=change-this-to-a-long-random-string
# Comma-separate multiple origins. Include localhost for local frontend hitting this API:
# CORS_ORIGIN=http://localhost:3000
# Production + local dev (example — use your real Vercel URL):
# CORS_ORIGIN=https://your-app.vercel.app,http://localhost:3000
CORS_ORIGIN=http://localhost:3000
# Optional: allow any https://*.vercel.app (preview URLs) while debugging
# CORS_ALLOW_VERCEL=true
# Optional (Railway/production): allow local Next.js (http://localhost:3000) to call this API
# without listing it in CORS_ORIGIN. Set true on Railway if you use NEXT_PUBLIC_API_URL
# pointing at production while developing locally.
# CORS_ALLOW_LOCALHOST=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Lucky draw: calendar-day boundaries for “approved on this day” use this offset (ISO 8601), default Mongolia
# DRAW_APPROVAL_TZ_OFFSET=+08:00

# --- Cloudflare R2 (receipt images). When set, uploads go to R2 and MongoDB stores the public HTTPS URL only.
# Create bucket + API token (Object Read & Write). Enable public access on the bucket or use a custom domain.
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ENDPOINT=https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# Public URL prefix (no trailing slash), e.g. https://pub-xxxxx.r2.dev or your custom domain
# R2_PUBLIC_BASE_URL=
